{
  "_common": {
    "ignore_dirs": [".git"]
  },
  "c": {
    "extensions": [".c"],
    "_extra_ignore_dirs_DISABLED": ["build"]
  },
  "cpp": {
    "extensions": [".cpp", ".cc", ".cxx"],
    "extra_ignore_dirs": ["build", "vendor"]
  },
  "haskell": {
    "extensions": [".hs"],
    "extra_ignore_dirs": ["build", "dist", "dist-newstyle", ".stack-work"]
  },
  "java": {
    "extensions": [".java"],
    "extra_ignore_dirs": ["build", "target"]
  },
  "javascript": {
    "extensions": [".js"],
    "extra_ignore_dirs": ["node_modules", "vendor"]
  },
  "php": {
    "extensions": [".php"],
    "grammar_subdir": "php",
    "extra_ignore_dirs": ["vendor", "node_modules"]
  },
  "python": {
    "extensions": [".py"],
    "extra_ignore_dirs": ["build", "__pycache__"]
  },
  "ruby": {
    "extensions": [".rb"],
    "extra_ignore_dirs": ["vendor", "node_modules"]
  },
  "smallbasic": {
    "extensions": [".sb"]
  },
  "typescript": {
    "extensions": [".ts"],
    "grammar_subdir": "typescript",
    "extra_ignore_dirs": [
      "__tests__", "spec", "specs", "dist",
      "node_modules", "vendor", "fixtures", "mocks", "__mocks__",
      "coverage"
    ]
  }
}
