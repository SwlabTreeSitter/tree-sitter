      "candidate_text": "class Car\n  @@makes = []\n  @@cars = {}\n  attr_reader :make\n  def self.total_count\n    @total_count ||= 0\n  end\n  def self.total_count=(n)\n    @total_count = n\n  end\n  def self.add_make(make)\n    unless @@makes.include?(make)\n      @@makes << make\n      @@cars[make] = 0\n    end\n  end\n  def initialize(make)\n    if @@makes.include?(make)\n      puts \"Creating a new #{make}!\"\n      @make = make\n      @@cars[make] += 1\n      self.class.total_count += 1\n    else\n      raise \"No such make: #{make}.\"\n    end\n  end\n  def make_mates\n    @@cars[self.make]\n  end\nend"
    }
